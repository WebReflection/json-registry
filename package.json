{
  "name": "json-registry",
  "version": "0.0.0",
  "type": "module",
  "types": "./types/index.d.ts",
  "main": "src/index.js",
  "module": "src/index.js",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run build:types",
    "build:types": "tsc --allowJs --checkJs --declaration --emitDeclarationOnly --stripInternal --outDir types --target es2022 --lib es2024 --module nodenext --moduleResolution nodenext src/*.js",
    "coverage": "mkdir -p ./coverage; c8 report --reporter=text-lcov > ./coverage/lcov.info",
    "test": "c8 node --localstorage-file './test/.storage' -e 'let q=Promise.resolve();for(const t of require(`./package.json`).tests)q=q.then(()=>import(`./test/${t}.js`));'"
  },
  "files": [
    "src",
    "types",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "JSON",
    "registry",
    "flatted"
  ],
  "author": "Andrea Giammarchi",
  "license": "MIT",
  "description": "A JSON registry for custom types",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WebReflection/json-registry.git"
  },
  "bugs": {
    "url": "https://github.com/WebReflection/json-registry/issues"
  },
  "homepage": "https://github.com/WebReflection/json-registry#readme",
  "overrides": {
    "c8": {
      "yargs": "^18.0.0"
    }
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "typescript": "^6.0.3"
  }
}
